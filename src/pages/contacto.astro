---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../data/config";
---

<Layout
  title="Contacto"
  description="Comuníquese con Blanco & Barrera Abogados. Estamos aquí para ayudarle con sus asuntos legales e inmobiliarios."
>
  <!-- Hero Section -->
  <section
    class="h-[40vh] md:h-[50vh] relative bg-[url('/images/bg-biblioteca-oscura.webp')] bg-cover bg-center flex items-center justify-start"
  >
    <div class="absolute inset-0 bg-black/60"></div>
    <div
      class="absolute bottom-0 left-0 right-0 h-4 bg-gradient-to-r from-brand-gold to-yellow-600 opacity-80 z-20"
    >
    </div>
    <div class="container-custom relative z-10 w-full text-left">
      <div
        class="bg-primary-950/80 inline-block px-12 py-6 rounded-r-3xl border-l-4 border-brand-gold backdrop-blur-sm shadow-2xl"
      >
        <h1
          class="text-4xl md:text-5xl font-bold font-serif text-brand-gold"
          style="text-shadow: 2px 2px 4px rgba(0,0,0,0.8);"
        >
          Contacto
        </h1>
      </div>
    </div>
  </section>

  <!-- Content ... actual files are complete -->
</Layout>
