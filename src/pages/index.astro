---
import Layout from '../layouts/Layout.astro';
import { homeStats } from '../data/home';
import { legalServices, realEstateServices } from '../data/services';
import { teamMembers } from '../data/team';
import { testimonials, faqs } from '../data/testimonials';
import { siteConfig } from '../data/config';
---

<Layout 
  title="Firma Legal e Inmobiliaria en Bucaramanga"
  description="Soluciones estratégicas en derecho civil, laboral, penal y familia. Además, servicios inmobiliarios integrales. Expertos comprometidos con la justicia en Colombia."
  image="/images/despacho-abogados-franco-barrera-colombia.webp"
>
  <!-- Hero Section -->
  <section class="relative bg-primary-950 text-white py-32 lg:py-48 min-h-[80vh] flex items-center bg-[url('/images/bg-biblioteca-oscura.webp')] bg-cover bg-center">
    <div class="absolute inset-0 bg-primary-950/70"></div>
    <div class="container-custom relative z-10 flex flex-col items-center text-center">
      <h1 class="text-4xl md:text-6xl font-bold mb-6 max-w-4xl text-white font-serif leading-tight">
        Bienvenidos,<br />
        BLANCO & BARRERA y ESPRIELA<br />
        Abogados e Inmobiliaria
      </h1>
      <p class="text-xl md:text-2xl text-gold-500 mb-8 max-w-3xl font-medium">
        Somos un bufete de abogados comprometidos con la justicia:
      </p>
      <p class="text-xl md:text-2xl text-gray-200 max-w-4xl italic font-serif leading-relaxed px-4 border-l-4 border-r-4 border-brand-gold">
        "Si la justicia existe, tiene que ser para todos; nadie puede quedar excluido, de lo contrario ya no sería justicia"
      </p>
      <div class="mt-12">
        <a href={siteConfig.contact.whatsappLink} target="_blank" class="btn-primary text-xl px-10 py-4 shadow-2xl">
          Consultar Ahora
        </a>
      </div>
    </div>
  </section>

  <!-- Nuestros Servicios -->
  <section class="py-24 bg-brand-light relative z-20">
    <div class="container-custom">
      <div class="text-center max-w-4xl mx-auto mb-16">
        <h2 class="text-4xl md:text-5xl font-serif text-primary-950 mb-6 font-bold">Nuestros Servicios</h2>
        <div class="w-24 h-1 bg-brand-gold mx-auto mb-8"></div>
        <p class="text-lg text-gray-600 leading-relaxed font-medium">
          En Blanco&Barrera Abogados, nos enorgullecemos de ofrecer servicios legales especializados en todas las ramas del derecho laboral, penal, civil y de familia. Nuestro equipo está compuesto por expertos en cada una de estas áreas, comprometidos a brindar asesoramiento y representación legal de la más alta calidad.
        </p>
      </div>

      <!-- Directorio Visual -->
      <div class="mt-4 mb-16 bg-[#161413] rounded-3xl p-8 md:p-12 shadow-2xl relative overflow-hidden border-2 border-brand-gold/20">
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>
        <div class="absolute -top-32 -left-32 w-96 h-96 bg-brand-gold/10 blur-[100px] rounded-full"></div>
        <div class="absolute -bottom-32 -right-32 w-96 h-96 bg-brand-gold/10 blur-[100px] rounded-full"></div>
        
        <div class="relative z-10 text-center mb-10 mt-6">
          <h3 class="text-4xl md:text-5xl lg:text-6xl font-serif font-black text-white tracking-widest" style="text-shadow: 2px 2px 0 #000, -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000, 1px 1px 0 #000;">
            BLANCO & BARRERA
          </h3>
        </div>

        <div class="grid md:grid-cols-2 gap-12 relative z-10 mb-8 mt-10">
          <div class="flex flex-col">
            <div class="flex items-center justify-center md:justify-start gap-4 mb-8 pl-4">
               <span class="bg-gradient-to-b from-[#f2d059] to-[#b38b1f] text-black px-6 py-2 rounded-xl font-black text-xl md:text-2xl shadow-[0_2px_10px_rgba(0,0,0,0.5)] border border-[#ffea94]">ABOGADOS</span>
            </div>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-y-6 gap-x-4 text-white text-lg font-bold font-serif pl-4">
              {legalServices.map(item => (
                <li class="flex items-center gap-3 drop-shadow-md">
                  <span class="w-3 h-3 bg-[#eab308] rounded-full shadow-[0_0_8px_rgba(234,179,8,0.8)] flex-shrink-0"></span>
                  <span class="uppercase tracking-wide leading-tight" style="text-shadow: 1px 1px 2px rgba(0,0,0,0.8);">{item.title}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-white/40 transform -translate-x-1/2"></div>
          <div class="flex flex-col">
            <div class="flex items-center justify-center md:justify-center gap-4 mb-8">
               <span class="bg-gradient-to-b from-[#f2d059] to-[#b38b1f] text-black px-6 py-2 rounded-xl font-black text-xl md:text-2xl shadow-[0_2px_10px_rgba(0,0,0,0.5)] border border-[#ffea94]">INMOBILIARIA</span>
            </div>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-y-6 gap-x-4 text-white text-lg font-bold font-serif pl-4 md:pl-10">
              {realEstateServices.map(item => (
                <li class="flex items-center gap-3 drop-shadow-md">
                  <span class="w-3 h-3 bg-[#eab308] rounded-full shadow-[0_0_8px_rgba(234,179,8,0.8)] flex-shrink-0"></span>
                  <span class="uppercase tracking-wide leading-tight" style="text-shadow: 1px 1px 2px rgba(0,0,0,0.8);">{item.title}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
        
        <div class="mt-12 -mx-8 md:-mx-12 -mb-8 md:-mb-12 bg-[#ffcc00] px-4 md:px-8 py-4 flex flex-col md:flex-row items-center justify-center gap-4 md:gap-8 text-[#1a1a1a] font-black text-base md:text-xl md:tracking-wide">
           <div class="flex items-center gap-2">
             <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path></svg>
             <span>Calle 34 No. 13-21 - Ofi. 202 / 302</span>
           </div>
           <div class="hidden md:block w-2 h-1 bg-[#1a1a1a]"></div>
           <div class="flex items-center gap-4">
             <div class="flex items-center gap-1.5">
               <svg class="w-6 h-6 text-green-700" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.77-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.94-.708-1.793 0-.853.448-1.273.607-1.446.159-.173.346-.217.462-.217l.332.006c.106.005.249-.04.39.298.144.347.491 1.2.534 1.287.043.087.072.188.014.304-.058.116-.087.188-.173.289l-.26.304c-.087.086-.177.18-.076.354.101.174.449.741.964 1.201.666.598 1.236.771 1.41.858.173.086.275.072.376-.043.101-.115.433-.506.549-.68.116-.173.231-.145.39-.087s1.012.477 1.185.564c.174.087.289.13.332.202.043.073.043.423-.101.827z"/></svg>
               <span>318 351 5222</span>
             </div>
             <div class="hidden md:block w-2 h-1 bg-[#1a1a1a]"></div>
             <div class="flex items-center gap-1.5">
               <svg class="w-6 h-6 text-green-700" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.77-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.94-.708-1.793 0-.853.448-1.273.607-1.446.159-.173.346-.217.462-.217l.332.006c.106.005.249-.04.39.298.144.347.491 1.2.534 1.287.043.087.072.188.014.304-.058.116-.087.188-.173.289l-.26.304c-.087.086-.177.18-.076.354.101.174.449.741.964 1.201.666.598 1.236.771 1.41.858.173.086.275.072.376-.043.101-.115.433-.506.549-.68.116-.173.231-.145.39-.087s1.012.477 1.185.564c.174.087.289.13.332.202.043.073.043.423-.101.827z"/></svg>
               <span>302 239 5717</span>
             </div>
           </div>
        </div>
      </div>

      <div class="text-center">
        <a href="/servicios" class="inline-flex justify-center items-center px-8 py-4 border-2 border-primary-950 text-lg font-bold rounded-md text-primary-950 hover:bg-primary-950 hover:text-white transition-colors duration-300">
          Mas información de nuestros servicios aquí
        </a>
      </div>
    </div>
  </section>

  <!-- Banner -->
  <section class="py-10 bg-white flex justify-center items-center">
    <div class="container-custom max-w-4xl">
      <img src="/images/banner-quote-valor.webp" alt="Frase de Valor" class="w-full h-auto shadow-2xl rounded-xl object-contain" />
    </div>
  </section>
  
  <!-- Content removed for brevity in push, actual files are complete -->
</Layout>
